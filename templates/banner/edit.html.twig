{% extends 'base.html.twig' %}

{% block title %}Edit Banner{% endblock %}

{% block body %}
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 mb-4">Edit Banner</h1>

            {{ include('banner/_form.html.twig', {'button_label': 'Update'}) }}

            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="{{ path('app_banner_index') }}">Back to list</a>
                {{ include('banner/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script src="/js/banner-form-collection.js"></script>
{% endblock %}
