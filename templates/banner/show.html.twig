{% extends 'base.html.twig' %}

{% block title %}Banner{% endblock %}

{% block body %}
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 mb-4">Banner details</h1>

            <div class="table-responsive mb-4">
                <table class="table table-bordered align-middle mb-0">
                    <tbody>
                        <tr>
                            <th>Id</th>
                            <td>{{ banner.id }}</td>
                        </tr>
                        <tr>
                            <th>Active</th>
                            <td>
                                <span class="badge {{ banner.active ? 'text-bg-success' : 'text-bg-secondary' }}">{{ banner.active ? 'Active' : 'Inactive' }}</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Internal_name</th>
                            <td>{{ banner.internalName }}</td>
                        </tr>
                        <tr>
                            <th>Start_date</th>
                            <td>{{ banner.startDate ? banner.startDate|date('Y-m-d') : '' }}</td>
                        </tr>
                        <tr>
                            <th>End_date</th>
                            <td>{{ banner.endDate ? banner.endDate|date('Y-m-d') : '' }}</td>
                        </tr>
                        <tr>
                            <th>Background_color</th>
                            <td>
                                {% if banner.backgroundColor %}
                                    {{ banner.backgroundColor.name }} ({{ banner.backgroundColor.code }})
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <h2 class="h5 mb-3">Translations</h2>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Language</th>
                            <th>Active</th>
                            <th>Content</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for translation in banner.bannerContents %}
                            <tr>
                                <td>{{ translation.language ? translation.language.name : '' }}</td>
                                <td>
                                    <span class="badge {{ translation.activeLang ? 'text-bg-success' : 'text-bg-secondary' }}">{{ translation.activeLang ? 'Active' : 'Inactive' }}</span>
                                </td>
                                <td>{{ translation.content }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">No translations found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 mt-4">
                <a class="btn btn-outline-secondary" href="{{ path('app_banner_index') }}">Back to list</a>
                <a class="btn btn-warning" href="{{ path('app_banner_edit', {'id': banner.id}) }}">Edit</a>
                {{ include('banner/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
